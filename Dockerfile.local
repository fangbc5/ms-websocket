# 简化版 Dockerfile - 使用本地构建的二进制文件
# 使用方法：
# 1. 本地构建：cargo build --release -p ms-websocket
# 2. 构建镜像：docker build -f ms-websocket/Dockerfile.local -t ms-websocket .
#    （在 workspace 根目录执行）

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    libssl3 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 从本地复制已编译的二进制文件
COPY target/release/ms-websocket /app/ms-websocket

# 设置工作目录
WORKDIR /app

# 暴露端口
EXPOSE 30001

# 设置环境变量
ENV APP__SERVER__ADDR=0.0.0.0

# 运行应用
ENTRYPOINT ["/app/ms-websocket"]
