# IM 服务器配置文件
# 复制此文件为 .env 并根据需要修改配置

# ===== 日志配置 =====
# 日志级别：trace, debug, info, warn, error
# 也可以使用过滤器语法，如：info,im_server=debug
RUST_LOG=info

# ===== 服务器配置 =====
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# ===== WebSocket 配置 =====
WRITE_CHANNEL_CAP=1024
HEARTBEAT_INTERVAL_SECS=20
HEARTBEAT_TIMEOUT_SECS=60

# ===== 广播器配置 =====
USE_KAFKA=false

# ===== Kafka 配置 =====
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=im-messages
KAFKA_CONSUMER_GROUP=im-server-consumer-group
KAFKA_PRODUCER_RETRIES=3
